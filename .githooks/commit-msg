#!/usr/bin/env bash
# Checks that a commit message follows Conventional Commits.
# Install with: bash tool/install_hooks.sh
set -euo pipefail

msg_file="$1"
first_line="$(head -n1 "$msg_file")"

# Let merge, revert, and fixup commits through untouched.
case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .+'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  cat >&2 <<'EOF'
Commit message does not follow Conventional Commits.

Expected:
  type(scope): summary

Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert.
The scope is optional. Examples:
  feat(providers): add Cohere text client
  fix: retry on a dropped connection
  docs: explain the retry policy
EOF
  exit 1
fi
